# Copy to .env and fill in real values. .env is git-ignored — never commit it.
# Consumed by scripts/generate-secret.sh to produce SealedSecret manifests.

# Cloudflare API token (scoped: Zone > DNS > Edit + Zone > Read on perihelion.live).
# Used by cert-manager's DNS-01 solver. Token strings start with "cfat_".
CLOUDFLARE_API_TOKEN=

# Pihole web admin password.
PIHOLE_PASSWORD=

# Traefik dashboard basic-auth credentials (hashed into an htpasswd secret).
TRAEFIK_DASHBOARD_USER=
TRAEFIK_DASHBOARD_PASSWORD=

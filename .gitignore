# Plain Kubernetes secrets - never commit these
# Use kubeseal to produce sealed-secret.yaml files instead
**/*-secret-plain.yaml
**/secret-plain.yaml

# temp staging area
/tmp/

# Local secret values consumed by k8s/scripts/generate-secret.sh — never commit
# (anchored: docker/.env is non-sensitive and IS committed)
/k8s/.env
/k8s/.env.local


.claude/settings.local.json

# Docker: SOPS-decrypted secrets (generated at deploy time, never commit)
docker/**/.secrets.env
# Docker: unencrypted staging file before SOPS encryption (use secrets.enc.env instead)
docker/**/secrets.env

# =============================================================================
# phis4 Docker Node — Non-Sensitive Configuration
# Safe to commit. Secrets live in services/**/secrets.enc.env (SOPS-encrypted).
# =============================================================================

# --- Host ---
TZ=America/Denver
PUID=1000
PGID=1000

# --- Storage ---
# /mnt/phis4/hot is the mergerfs pool — always use it, never a member disk
# like /mnt/phis4/ssd1. Libraries live directly under DATA_DIR
# (movies/, shows/, music/), alongside torrents/, usenet/, photos/, books/.
CONFIG_DIR=/mnt/phis4/hot/data
DATA_DIR=/mnt/phis4/hot/media

# --- Network ---
LOCAL_SUBNET=192.168.1.0/24

# --- Jellyfin ---
JELLYFIN_URI=http://media.perihelion.live
# JELLYFIN_URL is what jellysignal uses to reach Jellyfin — must be the host
# IP, not localhost (separate container network namespaces).
JELLYFIN_URL=http://192.168.1.215:8096
# Host-specific GIDs (getent group render video) — 993/44 on phis4.
JELLYFIN_RENDER_GROUP=993
JELLYFIN_VIDEO_GROUP=44

# --- VPN ---
# Quoted: setup.sh sources this file with bash, unquoted spaces break it.
VPN_SERVER_COUNTRIES="United States"

# --- Ports ---
# 8080 is taken by Nextcloud AIO on this host — do not reuse it here.
QBIT_WEBUI_PORT=8085
PROWLARR_PORT=9696
RADARR_PORT=7878
SONARR_PORT=8989
LIDARR_PORT=8686
BOOKSHELF_PORT=8787
READARR_PORT=8787
LAZYLIBRARIAN_PORT=5299
JELLYSEERR_PORT=5055
SABNZBD_PORT=8090
IMMICH_PORT=2283

# --- Immich ---
# Exact pin — bump intentionally; check breaking changes in release notes.
IMMICH_VERSION=v2.7.5
# The existing database cluster was initialized with user `postgres`; changing
# this without re-initializing the DB volume will break server auth.
IMMICH_DB_USERNAME=postgres
IMMICH_DB_DATABASE_NAME=immich

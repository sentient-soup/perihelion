# Media secrets — only needed when jellysignal is enabled (workflow: README.md).
# MUST be SOPS-encrypted before committing.

# Jellyfin API key (Admin Dashboard > API Keys)
JELLYFIN_API_KEY=REPLACE_ME

# TMDB API key (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=REPLACE_ME

# Random session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=REPLACE_ME
